DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# Optional — register commands to one guild (instant updates during dev)
# DISCORD_GUILD_ID=

# Optional
# DAILY_DOWNLOAD_LIMIT=5
# MAX_ATTACHMENT_MB=25
# REGISTER_COMMANDS_ON_START=true

# Local dev — read cookies from your browser (not available inside Docker)
# YTDLP_COOKIES_FROM_BROWSER=chrome

# Docker — mount cookies/ytdlp.txt (see cookies/README.md)
# YTDLP_COOKIES_FILE=/app/cookies/ytdlp.txt
